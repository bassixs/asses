BOT_TOKEN=your_telegram_bot_token
YANDEX_SPEECHKIT_API_KEY=your_yandex_speechkit_api_key
YANDEX_GPT_API_KEY=your_yandex_gpt_api_key
YANDEX_FOLDER_ID=your_yandex_cloud_folder_id

# Object Storage is required for long interview transcription via SpeechKit async API v2.
YANDEX_STORAGE_BUCKET=your-private-audio-bucket
YANDEX_STORAGE_ACCESS_KEY_ID=your_service_account_static_access_key_id
YANDEX_STORAGE_SECRET_ACCESS_KEY=your_service_account_static_secret_key
YANDEX_STORAGE_ENDPOINT=https://storage.yandexcloud.net
YANDEX_STORAGE_PREFIX=interviews

DATABASE_URL=sqlite+aiosqlite:///./data/app.db
LOG_LEVEL=INFO
DOWNLOAD_DIR=./data/uploads
TELEGRAM_DOWNLOAD_MAX_BYTES=20000000

# Optional. Use a local Telegram Bot API Server to receive files larger than the public Bot API limit.
# Example for a local server:
# TELEGRAM_API_BASE_URL=http://127.0.0.1:8081
# TELEGRAM_API_IS_LOCAL=true
# TELEGRAM_DOWNLOAD_MAX_BYTES=2000000000
TELEGRAM_FILE_REQUEST_TIMEOUT_SECONDS=900
TELEGRAM_FILE_DOWNLOAD_TIMEOUT_SECONDS=900
TELEGRAM_FILE_DOWNLOAD_ATTEMPTS=3
TELEGRAM_FILE_DOWNLOAD_RETRY_DELAY_SECONDS=15
# Per-attempt timeout for sending result documents (notebook/report/IPR/transcript).
TELEGRAM_FILE_SEND_TIMEOUT_SECONDS=180
TELEGRAM_DROP_PENDING_UPDATES_ON_START=false

# Optional. Structured output is best supported by rc in current YandexGPT docs.
YANDEX_GPT_MODEL_URI=gpt://your_yandex_folder_id/yandexgpt/rc

# Sync SpeechKit v1 limit is 1 MB / ~30 seconds. Long interviews need async STT.
SPEECHKIT_SYNC_MAX_BYTES=1000000
SPEECHKIT_ASYNC_API_VERSION=v3
SPEECHKIT_V3_MODEL=general:rc
SPEECHKIT_V3_ENABLE_SPEAKER_LABELING=true
SPEECHKIT_V3_FALLBACK_TO_V2=true
SPEECHKIT_ASYNC_POLL_INTERVAL_SECONDS=10
SPEECHKIT_ASYNC_TIMEOUT_SECONDS=7200
SPEECHKIT_DEDUPLICATE_TRANSCRIPT=true
SPEECHKIT_DEDUP_SIMILARITY_THRESHOLD=0.88
TRANSCRIPT_EXPORT_INCLUDE_TIMESTAMPS=false
TRANSCRIPT_EXPORT_MERGE_SAME_ROLE=true

# Optional test STT provider. The bot asks which engine to use for every uploaded audio file.
AITUNNEL_API_KEY=your_aitunnel_api_key
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1
AITUNNEL_WHISPER_MODEL=whisper-large-v3-turbo
AITUNNEL_LANGUAGE=ru
AITUNNEL_RESPONSE_FORMAT=json
AITUNNEL_TIMEOUT_SECONDS=1800
AITUNNEL_FORCE_IPV4=true
AITUNNEL_MAX_UPLOAD_BYTES=25000000

# Optional test STT provider. OpenAI-compatible NeuroAPI Whisper endpoint.
NEUROAPI_API_KEY=your_neuroapi_api_key
NEUROAPI_BASE_URL=https://neuroapi.host/v1
NEUROAPI_WHISPER_MODEL=whisper-1
NEUROAPI_LANGUAGE=ru
NEUROAPI_RESPONSE_FORMAT=json
NEUROAPI_TIMEOUT_SECONDS=1800
NEUROAPI_FORCE_IPV4=true
NEUROAPI_MAX_UPLOAD_BYTES=25000000

# Used to auto-compress long audio before uploading it to Whisper-compatible providers.
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
WHISPER_COMPRESSION_BITRATES_KBPS=32,24,16

# Chunking for AI Tunnel only (it enforces a hard 25 MB per-request limit). When even the
# lowest compression bitrate is still over the limit, audio is split into overlapping chunks,
# each transcribed separately and stitched back together. NeuroAPI/Yandex are unaffected.
WHISPER_CHUNK_ENABLED=true
WHISPER_CHUNK_BITRATE_KBPS=32
WHISPER_CHUNK_OVERLAP_SECONDS=15
WHISPER_CHUNK_MIN_SECONDS=60
WHISPER_CHUNK_SIZE_SAFETY=0.85
# Max audio seconds per Whisper request. Long recordings fit under 25 MB but can exceed
# the AI Tunnel gateway timeout (HTTP 524), so we also split by duration (~10 min/chunk).
WHISPER_CHUNK_MAX_SECONDS=600

# Optional. LLM post-processing that turns raw STT text into "Ведущий/Участник" dialogue.
ROLE_LABELING_ENABLED=true
# Provider options: aitunnel (default), neuroapi.
# Role labeling is accuracy-critical (3 speakers, no diarization) — use a strong model.
# gpt-5-mini: strong reasoning, cheaper than gpt-4o. Raise to gpt-5/gpt-4o if roles still wobble.
ROLE_LABELING_PROVIDER=aitunnel
ROLE_LABELING_MODEL=gpt-5-mini
ROLE_LABELING_TIMEOUT_SECONDS=900
# Larger chunk = whole exercise in one pass = consistent roles across role-play and debrief.
ROLE_LABELING_CHUNK_CHARS=14000
ROLE_LABELING_MAX_TOKENS=16000
ROLE_LABELING_TEMPERATURE=0
ROLE_LABELING_JSON_MODE=true

# LLM for /assess and observer notebook analysis.
# Provider options: aitunnel (default, cheap GPT-4o-mini), neuroapi, yandex.
ANALYSIS_LLM_PROVIDER=aitunnel
ANALYSIS_LLM_MODEL=gpt-4o-mini
ANALYSIS_LLM_TIMEOUT_SECONDS=900
ANALYSIS_LLM_TEMPERATURE=0.05
ANALYSIS_LLM_MAX_TOKENS=8000
# json_object response format: GPT-4o-mini honours it well, keep enabled for valid JSON.
ANALYSIS_LLM_JSON_MODE=true
# Observer notebook is analysed in batches of this many indicators per LLM call.
# Smaller batches are more reliable for big notebooks (avoids empty/truncated JSON).
NOTEBOOK_ANALYSIS_BATCH_SIZE=20
# How many analysis LLM calls run in parallel (notebook batches, report advice).
# Higher = faster but may hit provider rate limits. Lower if you see 429 errors.
ANALYSIS_LLM_MAX_CONCURRENCY=5

# Export DOCX report/IPR to PDF via LibreOffice (must be installed on the server).
PDF_EXPORT_ENABLED=true
LIBREOFFICE_BINARY=soffice
PDF_EXPORT_TIMEOUT_SECONDS=120

ADMIN_BOT_PASSWORD=1172

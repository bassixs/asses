BOT_TOKEN=your_telegram_bot_token
YANDEX_SPEECHKIT_API_KEY=your_yandex_speechkit_api_key
YANDEX_GPT_API_KEY=your_yandex_gpt_api_key
YANDEX_FOLDER_ID=your_yandex_cloud_folder_id

# Object Storage is required for long interview transcription via SpeechKit async API v2.
YANDEX_STORAGE_BUCKET=your-private-audio-bucket
YANDEX_STORAGE_ACCESS_KEY_ID=your_service_account_static_access_key_id
YANDEX_STORAGE_SECRET_ACCESS_KEY=your_service_account_static_secret_key
YANDEX_STORAGE_ENDPOINT=https://storage.yandexcloud.net
YANDEX_STORAGE_PREFIX=interviews

DATABASE_URL=sqlite+aiosqlite:///./data/app.db
LOG_LEVEL=INFO
DOWNLOAD_DIR=./data/uploads

# Optional. Structured output is best supported by rc in current YandexGPT docs.
YANDEX_GPT_MODEL_URI=gpt://your_yandex_folder_id/yandexgpt/rc

# Sync SpeechKit v1 limit is 1 MB / ~30 seconds. Long interviews need async STT.
SPEECHKIT_SYNC_MAX_BYTES=1000000
SPEECHKIT_ASYNC_POLL_INTERVAL_SECONDS=10
SPEECHKIT_ASYNC_TIMEOUT_SECONDS=7200

# Web admin panel. Keep WEB_HOST=127.0.0.1 unless it is protected by Nginx/VPN.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password
ADMIN_BOT_PASSWORD=1172
WEB_HOST=127.0.0.1
WEB_PORT=8080
